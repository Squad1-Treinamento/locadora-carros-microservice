server.port=8081
# DEPENDENDO DO SERVIÇO PRECISA TROCAR A PORTA, VERIFICA O GATEWAY CONTROLLER
spring.application.name=motorista-service
# DEPENDENDO DO SERVIÇO PRECISA TROCAR O NOME, PEGA NO GATEWAY CONTROLLER OS NOMES

# PostgreSQL COLOCA SEU BANCO AQUI, OU CRIA COM ESSE MESMO
spring.datasource.url=jdbc:postgresql://localhost:5432/locadora_carrosdb
spring.datasource.username=SEU_USUARIO
spring.datasource.password=SUA_SENHA
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true

